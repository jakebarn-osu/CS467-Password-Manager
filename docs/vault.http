### Vault endpoint tests
#
# Requires the VS Code REST Client extension (humao.rest-client):
# https://marketplace.visualstudio.com/items?itemName=humao.rest-client
# The vault routes require a Bearer token, so run the requests top to bottom.
# "Register user A" and "Login user A" must run before any vault request so the
# token variable resolves. Each request has a "Send Request" link above it.
#
# encryptedData is opaque to the server. It stores and returns the string as is,
# so any value works for testing. In the real app it is an AES-256-GCM base64 blob.

@host = http://localhost:5001
@authBase = {{host}}/api/v1/auth
@vaultBase = {{host}}/api/v1/vault

@emailA = alice@example.com
@authKeyA = alice-auth-key
@emailB = bob@example.com
@authKeyB = bob-auth-key
@salt = client-generated-salt

### Health check (expect 200 {"status":"ok"})
GET {{host}}/api/health

############################################################
# Setup: user A
############################################################

### Register user A (expect 201 {id, email}, or 409 if already registered)
POST {{authBase}}/register
Content-Type: application/json

{
  "email": "{{emailA}}",
  "authKey": "{{authKeyA}}",
  "salt": "{{salt}}"
}

### Login user A (expect 200 {token, tokenType, expiresIn})
# @name loginA
POST {{authBase}}/login
Content-Type: application/json

{
  "email": "{{emailA}}",
  "authKey": "{{authKeyA}}"
}

############################################################
# Vault happy path (user A)
############################################################

### Create a vault item (expect 201, encryptedData echoed back unchanged)
# @name createItemA
POST {{vaultBase}}/items
Authorization: Bearer {{loginA.response.body.$.token}}
Content-Type: application/json

{
  "encryptedData": "ENCRYPTED-BLOB-A-0001"
}

### List the user's vault items (expect 200 {items:[...]} containing the item above)
GET {{vaultBase}}/items
Authorization: Bearer {{loginA.response.body.$.token}}

### Get the created item by id (expect 200 with the same item)
GET {{vaultBase}}/items/{{createItemA.response.body.$.id}}
Authorization: Bearer {{loginA.response.body.$.token}}

############################################################
# Negative and validation cases
############################################################

### List without a token (expect 401 Unauthorized)
GET {{vaultBase}}/items

### Create with a missing body field (expect 400 Invalid request)
POST {{vaultBase}}/items
Authorization: Bearer {{loginA.response.body.$.token}}
Content-Type: application/json

{
}

### Get a well-formed but non-existent id (expect 404 Not found)
GET {{vaultBase}}/items/123e4567-e89b-42d3-a456-556642440000
Authorization: Bearer {{loginA.response.body.$.token}}

### Get a malformed id (expect 400, id must be a UUID)
GET {{vaultBase}}/items/not-a-uuid
Authorization: Bearer {{loginA.response.body.$.token}}

############################################################
# Per-user isolation (user B cannot see user A's item)
############################################################

### Register user B (expect 201, or 409 if already registered)
POST {{authBase}}/register
Content-Type: application/json

{
  "email": "{{emailB}}",
  "authKey": "{{authKeyB}}",
  "salt": "{{salt}}"
}

### Login user B (expect 200 with a token)
# @name loginB
POST {{authBase}}/login
Content-Type: application/json

{
  "email": "{{emailB}}",
  "authKey": "{{authKeyB}}"
}

### B tries to read A's item by id (expect 404, not 403, so existence never leaks)
GET {{vaultBase}}/items/{{createItemA.response.body.$.id}}
Authorization: Bearer {{loginB.response.body.$.token}}

### B lists their own items (expect 200 {"items":[]})
GET {{vaultBase}}/items
Authorization: Bearer {{loginB.response.body.$.token}}
