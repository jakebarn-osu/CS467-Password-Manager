POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5433

API_PORT=5001
FRONTEND_PORT=5173

# Server secrets — dev-only defaults below. Override with strong random values
# (e.g. `openssl rand -base64 48`) for any non-local environment.
JWT_SECRET=dev-only-insecure-secret-change-me
SALT_PEPPER=dev-only-insecure-pepper-change-me
JWT_EXPIRES_IN_SECONDS=900

# Allowed browser origin for CORS, plus auth rate-limit window and ceiling.
FRONTEND_ORIGIN=http://localhost:5173
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
